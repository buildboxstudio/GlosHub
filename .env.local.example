# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: Supabase Dashboard -> Project Settings -> API
#
# When these are present the app uses real Supabase Auth + Postgres.
# When they are absent, the app runs in DEMO MODE (mock data + local login).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
